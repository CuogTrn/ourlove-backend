# ============================================================
# OUR LOVE STORY - Backend Environment Variables
# ============================================================
# LƯU Ý: Thay đổi các giá trị theo cấu hình thực của bạn
# 
# Hướng dẫn cấu hình:
# 1. PostgreSQL URL từ Render:
#    - Truy cập https://dashboard.render.com
#    - Chọn PostgreSQL database của bạn
#    - Copy đúng DATABASE_URL từ "Internal Database URL" hoặc "External Database URL"
# 2. Cloudinary (giữ nguyên nếu đã có):
#    - Truy cập https://cloudinary.com
#    - Lấy API credentials từ Dashboard
# ============================================================

# 📦 DATABASE - PostgreSQL trên Render
# Format: postgresql://user:password@host:port/database
# Lấy từ Render Dashboard → PostgreSQL → Internal/External URL
DATABASE_URL=postgresql://your_user:your_password@your_render_host:5432/your_database

# 🖼️ CLOUDINARY - Lưu trữ ảnh
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# 🔐 ADMIN PASSWORD
ADMIN_PASSWORD=ourlove2025

# 🚀 PORT (mặc định: 3000)
PORT=3000
